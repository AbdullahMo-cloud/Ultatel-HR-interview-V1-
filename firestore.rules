rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidEvaluation(data) {
      return data.keys().hasAll(['id', 'date', 'interviewerName', 'candidateName', 'answers', 'scoreInfo', 'authorId']) &&
             data.id is string && data.id.size() <= 128 &&
             data.date is string && data.date.size() <= 64 &&
             data.interviewerName is string && data.interviewerName.size() <= 128 &&
             data.candidateName is string && data.candidateName.size() <= 128 &&
             data.authorId == request.auth.uid &&
             data.answers is map &&
             data.scoreInfo is map &&
             (
               (!('candidateEmail' in data) || (data.candidateEmail is string && data.candidateEmail.size() <= 256)) &&
               (!('candidatePhone' in data) || (data.candidatePhone is string && data.candidatePhone.size() <= 64))
             );
    }

    match /evaluations/{evaluationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || incoming().authorId == resource.data.authorId);
      allow delete: if isSignedIn();
    }
  }
}
